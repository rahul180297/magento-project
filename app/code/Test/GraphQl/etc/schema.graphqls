
type Query {
    
    products (
            id: String @doc(description: "Query by id.")
    ) : Products @resolver( class: "Test\\GraphQl\\Model\\Resolver\\Products")  @cache( cacheIdentity: "Test\\GraphQl\\Model\\Resolver\\Products\\Identity")
}

type Products {
    
    id  : String  @doc(description: "Query by id.") 
}