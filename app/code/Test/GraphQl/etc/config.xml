<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
	<default>
		<payment>
			<custom_payment_method>
				<active>1</active>
				<model>Test\GraphQl\Model\Payment\Custom_payment_method</model>
				<order_status>pending</order_status>
				<title>custom_payment_method</title>
				<allowspecific>0</allowspecific>
				<group>offline</group>
			</custom_payment_method>
		</payment>
		<carriers>
			<custom_shipping_method>
				<model>Test\GraphQl\Model\Carrier\Custom_shipping_method</model>
				<active>0</active>
				<title>custom_shipping_method</title>
				<name>custom_shipping_method</name>
				<price>0.00</price>
				<specificerrmsg>This shipping method is not available. To use this shipping method, please contact us.</specificerrmsg>
				<sallowspecific>0</sallowspecific>
			</custom_shipping_method>
		</carriers>
	</default>
</config>
