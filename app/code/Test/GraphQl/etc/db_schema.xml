<?xml version="1.0" ?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
	<table name="test_graphql_blog" resource="default" engine="innodb" comment="test_graphql_blog Table">
		<column xsi:type="int" name="blog_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity Id"/>
		<constraint xsi:type="primary" referenceId="PRIMARY">
			<column name="blog_id"/>
		</constraint>
		<column name="post" nullable="true" xsi:type="text" comment="post"/>
		<column name="is_active" nullable="true" xsi:type="smallint" comment="is_active" identity="false"/>
		<column name="author" nullable="true" xsi:type="varchar" comment="author" length="255"/>
		<column name="created_at" nullable="true" xsi:type="datetime" comment="created_at" default="CURRENT_TIMESTAMP"/>
		<column name="updated_at" nullable="true" xsi:type="datetime" comment="updated_at" default="CURRENT_TIMESTAMP" on_update="true"/>
	</table>
</schema>
