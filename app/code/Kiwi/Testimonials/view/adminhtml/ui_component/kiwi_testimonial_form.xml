<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <!-- ================================================= -->
    <!-- FORM ARGUMENT -->
    <!-- ================================================= -->
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                kiwi_testimonial_form.kiwi_testimonial_form_data_source
            </item>
        </item>
        <item name="label" xsi:type="string" translate="true">
            Testimonial Information
        </item>
        <item name="template" xsi:type="string">
            templates/form/collapsible
        </item>
    </argument>

    <!-- ================================================= -->
    <!-- FORM SETTINGS (BLOCK BUTTON PATTERN) -->
    <!-- ================================================= -->
    <settings>
        <buttons>
            <button name="back"
                    class="Kiwi\Testimonials\Block\Adminhtml\Testimonial\Edit\BackButton"/>
            <button name="delete"
                    class="Kiwi\Testimonials\Block\Adminhtml\Testimonial\Edit\DeleteButton"/>
            <button name="save"
                    class="Kiwi\Testimonials\Block\Adminhtml\Testimonial\Edit\SaveButton"/>
            <button name="save_and_continue"
                    class="Kiwi\Testimonials\Block\Adminhtml\Testimonial\Edit\SaveAndContinueButton"/>
        </buttons>

        <namespace>kiwi_testimonial_form</namespace>
        <dataScope>data</dataScope>

        <deps>
            <dep>kiwi_testimonial_form.kiwi_testimonial_form_data_source</dep>
        </deps>
    </settings>

    <!-- ================================================= -->
    <!-- DATA SOURCE -->
    <!-- ================================================= -->
    <dataSource name="kiwi_testimonial_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">
                    Magento_Ui/js/form/provider
                </item>
            </item>
        </argument>

        <settings>
            <submitUrl path="*/*/save"/>
        </settings>

        <dataProvider name="kiwi_testimonial_form_data_source"
                      class="Kiwi\Testimonials\Ui\DataProvider\Testimonial\Form\DataProvider">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <!-- ================================================= -->
    <!-- FIELDSET -->
    <!-- ================================================= -->
    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>

        <!-- ID (HIDDEN) -->
        <field name="id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>id</dataScope>
            </settings>
        </field>

        <field name="status">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="sortOrder" xsi:type="number">10</item>
                    <item name="dataType" xsi:type="string">boolean</item>
                    <item name="formElement" xsi:type="string">checkbox</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="label" xsi:type="string" translate="true">Status</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">false</item>
                    </item>
                    <item name="default" xsi:type="string">1</item>
                </item>
            </argument>
        </field>

        <!-- COMPANY NAME -->
        <field name="company_name" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Company Name</label>
                <dataScope>company_name</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">255</rule>
                </validation>
            </settings>
        </field>

        <!-- NAME -->
        <field name="name" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <dataScope>name</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">150</rule>
                </validation>
            </settings>
        </field>

        <!-- POST -->
        <field name="post" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Post / Designation</label>
                <dataScope>post</dataScope>
                <validation>
                    <rule name="max_text_length" xsi:type="number">150</rule>
                </validation>

            </settings>
        </field>

        <!-- MESSAGE -->
        <field name="message" formElement="textarea" sortOrder="50">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Message</label>
                <dataScope>message</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">1200</rule>
                    <rule name="min_text_length" xsi:type="number">10</rule>
                    <rule name="validate-no-html-tags" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">
                    Maximum 200 words (approx. 1200 characters)
                </notice>
            </settings>
        </field>

        <!-- PROFILE PIC -->
        <field name="profile_pic" formElement="imageUploader" sortOrder="50">
            <settings>
                <label translate="true">Profile Picture</label>
                <dataType>string</dataType>
                <dataScope>profile_pic</dataScope>
                <componentType>imageUploader</componentType>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg gif png</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                        <uploaderConfig>
                            <param xsi:type="string" name="url">testimonials/testimonial/upload</param>
                        </uploaderConfig>
                    </settings>
                </imageUploader>
            </formElements>
        </field>     

    </fieldset>
</form>
