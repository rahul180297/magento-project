<?php
/** @var \Kiwi\Testimonials\Block\Testimonials $block */
$testimonials = $block->getTestimonials();
?>

<?php if ($testimonials && $testimonials->getSize()): ?>
<section class="kiwi-testimonials">
    <div class="container">
        <h2><?= $escaper->escapeHtml(__('What Our Customers Say')) ?></h2>

        <div class="testimonial-slider">

            <?php foreach ($testimonials as $testimonial): ?>
                <!-- SINGLE SLIDE -->
                <div class="testimonial-slide">
                    <div class="testimonial-card">

                        <!-- HEADER -->
                        <div class="testimonial-header">

                            <?php if ($testimonial->getProfilePic()): ?>
                                <div class="testimonial-avatar">
                                    <img
                                        src="<?= $escaper->escapeUrl(
                                            $block->getMediaUrl() . "testimonial/". ltrim($testimonial->getProfilePic(), '/')
                                             ) ?>"
                                        alt="<?= $escaper->escapeHtml($testimonial->getName()) ?>"
                                    />
                                </div>
                            <?php endif; ?>

                            <div class="testimonial-meta">
                                <div class="testimonial-name">
                                    <?= $escaper->escapeHtml($testimonial->getName()) ?>
                                </div>

                                <?php if ($testimonial->getPost()): ?>
                                    <div class="testimonial-post">
                                        <?= $escaper->escapeHtml($testimonial->getPost()) ?>
                                    </div>
                                <?php endif; ?>

                                <?php if ($testimonial->getCompanyName()): ?>
                                    <div class="testimonial-company">
                                        <?= $escaper->escapeHtml($testimonial->getCompanyName()) ?>
                                    </div>
                                <?php endif; ?>
                            </div>

                        </div>

                        <!-- MESSAGE -->
                        <div class="testimonial-message">
                            “<?= $escaper->escapeHtml($testimonial->getMessage()) ?>”
                        </div>

                    </div>
                </div>
            <?php endforeach; ?>

        </div>
    </div>
</section>

