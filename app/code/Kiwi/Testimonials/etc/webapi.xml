<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- GET testimonial by ID -->
    <route url="/V1/testimonials/:id" method="GET">
        <service
            class="Kiwi\Testimonials\Api\TestimonialRepositoryInterface"
            method="getById"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- CREATE / UPDATE testimonial -->
    <route url="/V1/testimonials" method="POST">
        <service
            class="Kiwi\Testimonials\Api\TestimonialRepositoryInterface"
            method="save"/>
        <resources>
            <resource ref="Magento_Backend::admin"/>
        </resources>
    </route>

    <!-- DELETE testimonial -->
    <route url="/V1/testimonials/:id" method="DELETE">
        <service
            class="Kiwi\Testimonials\Api\TestimonialRepositoryInterface"
            method="deleteById"/>
        <resources>
            <resource ref="Magento_Backend::admin"/>
        </resources>
    </route>

</routes>
