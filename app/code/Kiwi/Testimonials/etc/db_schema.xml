<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="kiwi_testimonials" resource="default" engine="innodb" comment="Testimonials Table">
        <column name="id" xsi:type="int" nullable="false" identity="true" unsigned="true"/>
        <column name="company_name" xsi:type="varchar" length="255"/>
        <column name="name" xsi:type="varchar" length="255"/>
        <column name="message" xsi:type="text"/>
        <column name="post" xsi:type="varchar" length="255"/>
        <column name="profile_pic" xsi:type="varchar" length="255"/>
        <column name="status" xsi:type="smallint" default="1"/>
        <column name="created_at" xsi:type="timestamp" default="CURRENT_TIMESTAMP"/>
        <column name="updated_at" xsi:type="timestamp" on_update="true"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>
</schema>
